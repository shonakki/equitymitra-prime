# Angel One SmartAPI credentials — get from https://smartapi.angelbroking.com/
ANGEL_API_KEY=your_smartapi_key
ANGEL_CLIENT_CODE=A1234567
ANGEL_PASSWORD=your_mpin_or_password
ANGEL_TOTP_SECRET=BASE32SECRETFROM2FAQR

# Server
PORT=8080
NODE_ENV=production

# CORS — comma separated list of allowed frontend origins
ALLOWED_ORIGINS=https://equitymitra.com,https://www.equitymitra.com

# Optional: shared secret your frontend must send as `x-em-key` header
# Leave blank to disable. Strongly recommended in production.
FRONTEND_SHARED_SECRET=
