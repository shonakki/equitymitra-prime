# ─── Angel One SmartAPI ───────────────────────────────────────────────────────
ANGEL_API_KEY=your_smartapi_key
ANGEL_CLIENT_CODE=A1234567
ANGEL_PASSWORD=your_mpin_or_password
ANGEL_TOTP_SECRET=BASE32SECRETFROM2FAQR

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://equitymitra.com,https://www.equitymitra.com

# ─── Shared secret (optional) ────────────────────────────────────────────────
# If set, frontend must send `x-em-key` header
FRONTEND_SHARED_SECRET=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-string

# ─── Razorpay ────────────────────────────────────────────────────────────────
# Get from: https://razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) for development
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── SMS / OTP ───────────────────────────────────────────────────────────────
# MSG91: https://msg91.com → Get API Key + OTP Template
# If not set, OTPs are logged to Railway console (dev mode)
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=EQMTRA

# Resend: https://resend.com → Get API Key
# If not set, Email OTPs are logged to Railway console (dev mode)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → Create OAuth Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Admin Access ────────────────────────────────────────────────────────────
# Comma-separated phone numbers that get admin access (10 digits, no +91)
ADMIN_PHONES=9999999999

# ─── Database ─────────────────────────────────────────────────────────────────
# Optional: where to store SQLite file. Defaults to ./data/equitymitra.db
# On Railway, set to /data if using a volume mount
DATA_DIR=/data
